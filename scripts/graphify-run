#!/usr/bin/env bash
# scripts/graphify-run — portable Graphify wrapper for Claude/Codex subagents.
#
# Subagents often run with a minimal PATH that excludes ~/.local/bin.
# This script tries common install locations before giving up.
# Usage: ./scripts/graphify-run query "<question>"
#        ./scripts/graphify-run explain "<symbol>"
#        ./scripts/graphify-run path "<A>" "<B>"
#        ./scripts/graphify-run hook status
set -euo pipefail

GRAPHIFY_BIN=""

if command -v graphify >/dev/null 2>&1; then
  GRAPHIFY_BIN="graphify"
elif [ -x "$HOME/.local/bin/graphify" ]; then
  GRAPHIFY_BIN="$HOME/.local/bin/graphify"
elif [ -x "$HOME/.cargo/bin/graphify" ]; then
  GRAPHIFY_BIN="$HOME/.cargo/bin/graphify"
elif [ -x "/opt/homebrew/bin/graphify" ]; then
  GRAPHIFY_BIN="/opt/homebrew/bin/graphify"
elif [ -x "/usr/local/bin/graphify" ]; then
  GRAPHIFY_BIN="/usr/local/bin/graphify"
fi

if [ -z "$GRAPHIFY_BIN" ]; then
  echo "Graphify is not installed or not on PATH." >&2
  echo "Install with: uv tool install graphifyy" >&2
  echo "Then run:     graphify hook install" >&2
  exit 127
fi

exec "$GRAPHIFY_BIN" "$@"
